#   --- FUNCTION TO READ AND SORT CSV ---
#   ' Utilizes pathlib to read target   '
#   ' CSV file to parse data and store  '
#   ' in pandas DataFrame for analysis  '

import pandas as pd
from pathlib import Path
import matplotlib.pyplot as plt

def sortcsv(name_of_csv):
    # Path to file and read lines
    PATH_TO_READING = Path('path/to/parent/directory') / name_of_csv
    lines = PATH_TO_READING.read_text().splitlines()

    # Find cutoff after "--- STARTING DATA STREAM ---"
    cutoff = next(i + 1 for i, line in enumerate(lines) if line.strip() == '--- STARTING DATA STREAM ---')

    # Keep only data lines (non-empty, starting with "Time:")
    data_lines = [line for line in lines[cutoff:] if line.startswith('Time:')]

    # Parse each line into a dictionary by splitting on ',' and ':'
    data_dict = []
    for line in data_lines:
        reading = line.split(',')
        entry = {}
        for item in reading:
            key, value = item.split(':', 1)
            entry[key.strip()] = value.strip()
        data_dict.append(entry)

    PUTTYLOG_DF = pd.DataFrame(data_dict)

    # Convert 'Time' from ms to sec
    PUTTYLOG_DF['Time'] = [t / 1000 for t in PUTTYLOG_DF['Time'].astype(float)]

    # Convert columns to numeric types for data analysis
    cols = ['Time', 'Temp', 'Hum', 'TEC_PWM', 'CO2', 'O2']
    for col in cols:
        PUTTYLOG_DF[col] = pd.to_numeric(PUTTYLOG_DF[col])

    PUTTYLOG_DF.to_csv(PATH_TO_READING.parent / 'Processed_Raw' / (f'Processed_{PATH_TO_READING.name}'), index=False)
    
    return PUTTYLOG_DF

sortcsv()

#   --- PLOT DATA FROM CSV FOR VALIDATION ---
#   '  Utilizes the processed CSV for data  '
#   '  to plot and validate the readings    '
from pathlib import Path
import pandas as pd
import matplotlib.pyplot as plt

def plot_data(name_of_csv):
    PATH_TO_PROCESSED = Path('path/to/parent/directory') / 'Processed_Raw' / f'Processed_{name_of_csv}'
    DF = pd.read_csv(PATH_TO_PROCESSED)

    plt.figure(figsize=(12, 6))
    plt.plot(DF['Time'], DF['Temp'], label='Temperature (°C)', color='red')
    plt.plot(DF['Time'], DF['Hum'], label='Humidity (%)', color='blue')
    plt.plot(DF['Time'], DF['CO2'], label='CO2 (ppm)', color='green')
    plt.plot(DF['Time'], DF['O2'], label='O2 (%)', color='orange')
    plt.xlabel('Time (s)')
    plt.ylabel('Sensor Readings')
    plt.title('Sensor Data Over Time')
    plt.legend()
    plt.grid()
    plt.show()

    fig, axT = plt.subplots(figsize=(7, 2.7))
    axT.plot(DF['Time'], DF['Temp'], label='Temperature (°C)', color='red', linewidth=3)
    axT.set_xlabel('Time (s)')
    axT.set_ylabel('Temperature (°C)')

    fig, axH = plt.subplots(figsize=(7, 2.7))
    axH.plot(DF['Time'], DF['Hum'], label='Humidity (%)', color='blue', linewidth=3)
    axH.set_xlabel('Time (s)')
    axH.set_ylabel('Humidity (%)')

    fig, axC = plt.subplots(figsize=(7, 2.7))
    axC.plot(DF['Time'], DF['CO2'], label='CO2 (%)', color='green', linewidth=3)
    axC.set_xlabel('Time (s)')
    axC.set_ylabel('CO2 (ppm)')

    fig, axO = plt.subplots(figsize=(7, 2.7))
    axO.plot(DF['Time'], DF['O2'], label='O2 (%)', color='orange', linewidth=3)
    axO.set_xlabel('Time (s)')
    axO.set_ylabel('O2 (%)')

plot_data()
